import requests
import json
from action_schema import extract_action

class QwenAgent:
    def __init__(self):
        self.base_url = "http://127.0.0.1:11434/v1/chat/completions"
        self.model = "qwen2.5-coder:32b"

    def next_action(self, goal, memory, last_observation):
        messages = [
            {"role": "system", "content": "Return ONLY valid JSON action."},
            {"role": "user", "content": goal}
        ]

        if last_observation:
            messages.append({
                "role": "user",
                "content": json.dumps(last_observation)
            })

        payload = {
            "model": self.model,
            "messages": messages,
            "temperature": 0.2
        }

        res = requests.post(self.base_url, json=payload, timeout=60)
        res.raise_for_status()

        raw = res.json()["choices"][0]["message"]["content"]
        print("QWEN RAW:", raw)

        return extract_action(raw)
